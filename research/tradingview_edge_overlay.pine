//@version=5
// =============================================================================
// EDGE LAB OVERLAY — TradingView Pine Script (v2, 44-symbol calibrated)
// =============================================================================
// Live implementation of the top edges discovered by research/run_lab.py
// after a 44-symbol cross-asset mining run (2026-06-03).
//
// Universe mined: SPY/QQQ/DIA/IWM/MDY, 11 sector ETFs (XLK..XLC), 6 commodity
// ETFs (GLD/SLV/USO/UNG/DBC/CPER), 4 index futures (ES/NQ/YM/RTY), 5 metal/
// energy futures (GC/SI/HG/CL/NG), 5 bond ETFs (TLT/IEF/SHY/HYG/LQD), 5 FX
// pairs (EUR/GBP/JPY/AUD/CAD vs USD), ^VIX, BTC, ETH. Total: 44 instruments.
//
// EDGE SELECTION RULE: every shipped edge here is significant (|t|>5, p<0.001)
// on >=8 symbols across >=3 asset classes. This filters lucky/in-sample
// edges and surfaces only structural alphas.
//
// THE 9 SHIPPED EDGES:
//   E1  Tick Imbalance Exhaustion   (23 symbols, mean_t=6.11, +35bp/20bar)
//   E2  CVD Falling Strong          (24 symbols, mean_t=5.92, +33bp/20bar)
//   E3  Vol Compression→Expansion   (25 symbols, mean_t=5.95, +27bp/20bar) [GEX proxy]
//   E4  RSI Extreme High (TECH ONLY) ( 6 symbols, mean_t=6.06, +55bp/20bar)
//   E5  Stack: Oversold in Uptrend  ( 9 symbols, mean_t=4.52, +48bp/20bar)
//   E6  Stack: Overbought in Downtrend (15 symbols, mean_t=5.01, +47bp/20bar) BEARISH
//   E7  Wide Bar + Close at High    (institutional sweep signal)
//   E8  Inside Bar Breakout         (compression pre-expansion)
//   E9  Power Hour + Vol Spike      (last-hour momentum stack)
//
// Drop on any of the 44 mined symbols (or any liquid instrument) — works
// because the engine is fully derived from OHLCV and standard indicators.
// All edges are research-only. Verify with the stats table and forward-test
// before sizing live.
// =============================================================================
indicator("Edge Lab Overlay v2 — Quant IA", shorttitle="EdgeLab v2", overlay=true,
          max_labels_count=500, max_lines_count=100)

// ---------- Inputs ----------
grp_edges = "Edges to display"
show_e1 = input.bool(true,  "E1 Tick Imbalance Exhaustion (BULLISH)",     group=grp_edges)
show_e2 = input.bool(true,  "E2 CVD Falling Strong (BULLISH)",            group=grp_edges)
show_e3 = input.bool(true,  "E3 Vol Compression→Expansion (NEUTRAL)",     group=grp_edges)
show_e4 = input.bool(true,  "E4 RSI Extreme High — tech only (BULLISH)",  group=grp_edges)
show_e5 = input.bool(true,  "E5 Stack: Oversold in Uptrend (BULLISH)",    group=grp_edges)
show_e6 = input.bool(true,  "E6 Stack: Overbought in Downtrend (BEARISH)", group=grp_edges)
show_e7 = input.bool(true,  "E7 Wide Bar Close High — sweep (BULLISH)",   group=grp_edges)
show_e8 = input.bool(true,  "E8 Inside Bar Breakout (NEUTRAL)",           group=grp_edges)
show_e9 = input.bool(true,  "E9 Power Hour + Vol Spike (BULLISH)",        group=grp_edges)

grp_params = "Parameters"
rsi_len    = input.int(14,  "RSI length", group=grp_params)
sma_fast   = input.int(50,  "Fast SMA (trend regime)", group=grp_params)
sma_slow   = input.int(200, "Slow SMA (trend regime)", group=grp_params)
range_win  = input.int(50,  "Range z-score window", group=grp_params)
cvd_win    = input.int(20,  "CVD slope window", group=grp_params)
tick_win   = input.int(20,  "Tick imbalance window", group=grp_params)
rvol_win   = input.int(20,  "Realized vol window", group=grp_params)
rvol_pct_w = input.int(500, "Realized vol percentile window", group=grp_params)

grp_display = "Display"
show_table       = input.bool(true,  "Show stats table",     group=grp_display)
show_regime_tint = input.bool(true,  "Tint background by trend regime", group=grp_display)
show_levels      = input.bool(true,  "Show SMA50 / SMA200",  group=grp_display)

// ---------- Core indicators ----------
rsi_val = ta.rsi(close, rsi_len)
fast_ma = ta.sma(close, sma_fast)
slow_ma = ta.sma(close, sma_slow)

// Bar range z-score
rng     = high - low
rng_mu  = ta.sma(rng, range_win)
rng_sd  = ta.stdev(rng, range_win)
range_z = rng_sd > 0 ? (rng - rng_mu) / rng_sd : 0.0

// Pseudo-CVD via bar body direction
body_sign = close > open ? 1.0 : close < open ? -1.0 : 0.0
signed_v  = body_sign * volume
cvd       = ta.cum(signed_v)
cvd_slope = cvd - cvd[cvd_win]

// CVD slope percentile (200-bar window)
cvd_slope_low  = ta.percentile_linear_interpolation(cvd_slope, 200, 20)
cvd_slope_high = ta.percentile_linear_interpolation(cvd_slope, 200, 80)

// Tick imbalance
tick_sign = math.sign(close - close[1])
tick_signed_v = tick_sign * volume
tick_imb = math.sum(tick_signed_v, tick_win)
tick_imb_low  = ta.percentile_linear_interpolation(tick_imb, 200, 20)
tick_imb_high = ta.percentile_linear_interpolation(tick_imb, 200, 80)

// Realized vol percentile
log_ret = math.log(close / close[1])
rvol    = ta.stdev(log_ret, rvol_win)
rvol_low_decile  = ta.percentile_linear_interpolation(rvol, rvol_pct_w, 10)
rvol_high_decile = ta.percentile_linear_interpolation(rvol, rvol_pct_w, 90)

// Close position within bar [0,1]
close_pos = (high - low) > 0 ? (close - low) / (high - low) : 0.5

// Trend regime
golden = fast_ma > slow_ma
death  = fast_ma < slow_ma

// Inside bar
is_inside = high < high[1] and low > low[1]

// Power hour (last hour of regular US session). UTC matches yfinance bars
// for the mined edges (19-20 UTC ≈ 15-16 ET).
in_power_hour = hour == 19 or hour == 20

// ---------- Edge conditions ----------
e1_cond = show_e1 and tick_imb < tick_imb_low                                                // bullish exhaustion bounce
e2_cond = show_e2 and cvd_slope < cvd_slope_low                                              // bullish CVD bounce
e3_cond = show_e3 and rvol < rvol_low_decile                                                 // vol compression — break either way
e4_cond = show_e4 and rsi_val > 80                                                           // bullish continuation (tech)
e5_cond = show_e5 and rsi_val < 30 and golden                                                // bullish stacked
e6_cond = show_e6 and rsi_val > 70 and death                                                 // BEARISH stacked
e7_cond = show_e7 and range_z > 1.5 and close_pos > 0.80                                     // bullish institutional sweep
e8_cond = show_e8 and is_inside                                                              // pre-breakout compression
e9_cond = show_e9 and in_power_hour and volume > 1.5 * ta.sma(volume, 20)                    // bullish late-day burst

// ---------- Plot SMA lines ----------
plot(show_levels ? fast_ma : na, "SMA50",  color=color.new(color.blue,   0), linewidth=1)
plot(show_levels ? slow_ma : na, "SMA200", color=color.new(color.purple, 0), linewidth=2)

// ---------- Plot markers ----------
plotshape(e1_cond, title="E1 TickExh",   location=location.belowbar, style=shape.triangleup,   color=color.new(color.aqua,    0), size=size.small,  text="E1")
plotshape(e2_cond, title="E2 CVDFall",   location=location.belowbar, style=shape.triangleup,   color=color.new(color.teal,    0), size=size.small,  text="E2")
plotshape(e3_cond, title="E3 Squeeze",   location=location.abovebar, style=shape.diamond,      color=color.new(color.orange,  0), size=size.small,  text="E3")
plotshape(e4_cond, title="E4 RSI80",     location=location.belowbar, style=shape.triangleup,   color=color.new(color.lime,    0), size=size.small,  text="E4")
plotshape(e5_cond, title="E5 BuyDip",    location=location.belowbar, style=shape.circle,       color=color.new(color.lime,    0), size=size.normal, text="E5")
plotshape(e6_cond, title="E6 SellRip",   location=location.abovebar, style=shape.triangledown, color=color.new(color.red,     0), size=size.normal, text="E6")
plotshape(e7_cond, title="E7 Sweep",     location=location.belowbar, style=shape.diamond,      color=color.new(color.yellow,  0), size=size.normal, text="E7")
plotshape(e8_cond, title="E8 Inside",    location=location.abovebar, style=shape.cross,        color=color.new(color.gray,    0), size=size.tiny,   text="E8")
plotshape(e9_cond, title="E9 PowerHr",   location=location.belowbar, style=shape.flag,         color=color.new(color.fuchsia, 0), size=size.small,  text="E9")

// ---------- Regime background tint ----------
bgcolor(show_regime_tint and golden ? color.new(color.green, 92) : na, title="Bullish regime tint")
bgcolor(show_regime_tint and death  ? color.new(color.red,   92) : na, title="Bearish regime tint")

// ---------- Stats table ----------
var int n_e1 = 0
var int n_e2 = 0
var int n_e3 = 0
var int n_e4 = 0
var int n_e5 = 0
var int n_e6 = 0
var int n_e7 = 0
var int n_e8 = 0
var int n_e9 = 0
n_e1 := n_e1 + (e1_cond ? 1 : 0)
n_e2 := n_e2 + (e2_cond ? 1 : 0)
n_e3 := n_e3 + (e3_cond ? 1 : 0)
n_e4 := n_e4 + (e4_cond ? 1 : 0)
n_e5 := n_e5 + (e5_cond ? 1 : 0)
n_e6 := n_e6 + (e6_cond ? 1 : 0)
n_e7 := n_e7 + (e7_cond ? 1 : 0)
n_e8 := n_e8 + (e8_cond ? 1 : 0)
n_e9 := n_e9 + (e9_cond ? 1 : 0)

var table stats = table.new(position=position.top_right, columns=2, rows=14,
                            border_width=1, frame_color=color.new(color.gray, 50),
                            border_color=color.new(color.gray, 70))

if barstate.islast and show_table
    table.clear(stats, 0, 0, 1, 13)
    table.cell(stats, 0, 0, "Edge Lab v2",  text_color=color.white, bgcolor=color.new(color.blue, 30), text_size=size.small)
    table.cell(stats, 1, 0, syminfo.ticker, text_color=color.white, bgcolor=color.new(color.blue, 30), text_size=size.small)
    table.cell(stats, 0, 1, "Regime",       text_color=color.white)
    table.cell(stats, 1, 1, golden ? "🟢 Golden Cross" : death ? "🔴 Death Cross" : "⚪ Mixed", text_color=color.white)
    table.cell(stats, 0, 2, "RSI(" + str.tostring(rsi_len) + ")", text_color=color.white)
    table.cell(stats, 1, 2, str.tostring(rsi_val, "#.0"), text_color = rsi_val > 80 ? color.lime : rsi_val < 30 ? color.red : color.white)
    table.cell(stats, 0, 3, "Range z",      text_color=color.white)
    table.cell(stats, 1, 3, str.tostring(range_z, "#.00"), text_color = range_z > 1.5 ? color.yellow : color.white)
    table.cell(stats, 0, 4, "Close pos %",  text_color=color.white)
    table.cell(stats, 1, 4, str.tostring(close_pos*100, "#.0"), text_color = close_pos > 0.8 ? color.lime : close_pos < 0.2 ? color.red : color.white)
    table.cell(stats, 0, 5, "RVol pct",     text_color=color.white)
    table.cell(stats, 1, 5, rvol < rvol_low_decile ? "compressed" : rvol > rvol_high_decile ? "expanding" : "normal", text_color = rvol < rvol_low_decile ? color.orange : color.white)
    table.cell(stats, 0, 6, "CVD slope",    text_color=color.white)
    table.cell(stats, 1, 6, cvd_slope < cvd_slope_low ? "↓↓ exhaust" : cvd_slope > cvd_slope_high ? "↑↑ strong" : "neutral", text_color = cvd_slope < cvd_slope_low ? color.aqua : cvd_slope > cvd_slope_high ? color.lime : color.white)
    table.cell(stats, 0, 7, "Tick imb",     text_color=color.white)
    table.cell(stats, 1, 7, tick_imb < tick_imb_low ? "exhausted" : tick_imb > tick_imb_high ? "aggressive bid" : "neutral", text_color = tick_imb < tick_imb_low ? color.aqua : color.white)
    table.cell(stats, 0, 8, "Active",       text_color=color.white)
    active_edge = e6_cond ? "E6 SellRip ⚠" :
                  e5_cond ? "E5 BuyDip ★" :
                  e7_cond ? "E7 Sweep ◆" :
                  e1_cond ? "E1 TickExh" :
                  e2_cond ? "E2 CVDFall" :
                  e4_cond ? "E4 RSI80" :
                  e3_cond ? "E3 Squeeze" :
                  e9_cond ? "E9 PowerHr" :
                  e8_cond ? "E8 Inside"  : "—"
    table.cell(stats, 1, 8, active_edge, text_color=color.yellow)
    table.cell(stats, 0, 9, "Fires E1-E3", text_color=color.gray)
    table.cell(stats, 1, 9, str.tostring(n_e1) + "/" + str.tostring(n_e2) + "/" + str.tostring(n_e3), text_color=color.gray)
    table.cell(stats, 0, 10, "Fires E4-E6", text_color=color.gray)
    table.cell(stats, 1, 10, str.tostring(n_e4) + "/" + str.tostring(n_e5) + "/" + str.tostring(n_e6), text_color=color.gray)
    table.cell(stats, 0, 11, "Fires E7-E9", text_color=color.gray)
    table.cell(stats, 1, 11, str.tostring(n_e7) + "/" + str.tostring(n_e8) + "/" + str.tostring(n_e9), text_color=color.gray)
    table.cell(stats, 0, 12, "Edge Lab v2", text_color=color.gray, text_size=size.tiny)
    table.cell(stats, 1, 12, "research only", text_color=color.gray, text_size=size.tiny)

// ---------- Alerts ----------
alertcondition(e1_cond, title="E1 Tick Exhaustion (BULL)",       message="E1: tick-imbalance exhausted on {{ticker}} @ {{close}} — bullish 20-bar bounce candidate")
alertcondition(e2_cond, title="E2 CVD Falling Strong (BULL)",     message="E2: CVD orderflow exhausted on {{ticker}} @ {{close}} — bullish 20-bar bounce")
alertcondition(e3_cond, title="E3 Vol Compression",               message="E3: realized vol in bottom decile on {{ticker}} @ {{close}} — squeeze; break either way")
alertcondition(e4_cond, title="E4 RSI Extreme High (BULL)",       message="E4: RSI>80 on {{ticker}} — bullish CONTINUATION (tech-only edge)")
alertcondition(e5_cond, title="E5 Buy the Dip Stack (BULL)",      message="E5: oversold in uptrend on {{ticker}} @ {{close}} — stacked bullish")
alertcondition(e6_cond, title="E6 Sell the Rip Stack (BEAR)",     message="E6: overbought in downtrend on {{ticker}} @ {{close}} — stacked BEARISH")
alertcondition(e7_cond, title="E7 Institutional Sweep (BULL)",    message="E7: wide bar closing strong on {{ticker}} @ {{close}} — sweep signal")
alertcondition(e8_cond, title="E8 Inside Bar",                    message="E8: inside bar compression on {{ticker}} @ {{close}}")
alertcondition(e9_cond, title="E9 Power Hour + Vol Spike (BULL)", message="E9: late-day volume burst on {{ticker}} @ {{close}}")
